{
  "name": "@agentforge/api",
  "version": "0.0.0",
  "private": true,
  "description": "NestJS control-plane API (BFF): tenant/workspace/project management, agent registry & versioning.",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "dev": "node --import tsx --watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentforge/agent-core": "workspace:*",
    "@agentforge/db": "workspace:*",
    "@agentforge/governance": "workspace:*",
    "@agentforge/identity": "workspace:*",
    "@agentforge/providers": "workspace:*",
    "@agentforge/telemetry": "workspace:*",
    "@agentforge/tools": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^10.4.15",
    "@opentelemetry/api": "^1.9.0",
    "cookie-parser": "^1.4.7",
    "drizzle-orm": "^0.45.2",
    "openid-client": "^5.7.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2"
  }
}
