# ---------------------------------------------------------------------------------
# DEV-ONLY defaults for the local docker stack. These are NOT secrets and must NEVER
# be used outside local development. Production supplies all secret material via the
# secrets adapter (Vault) / your orchestrator — never a checked-in file.
#
# Copy to `.env` (gitignored) to override, or just rely on the compose defaults.
# ---------------------------------------------------------------------------------

# Postgres (bootstrap superuser used for migrations)
POSTGRES_PASSWORD=postgres

# Vault dev-mode root token
VAULT_DEV_ROOT_TOKEN=root

# Keycloak bootstrap admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Grafana admin (anonymous admin is also enabled for convenience)
GRAFANA_ADMIN_PASSWORD=admin

# Application secrets seeded into Vault by the `vault-seed` service.
# (The OIDC client secret must match the value in keycloak/realm-agentforge.json.)
APP_SESSION_SECRET=dev-session-secret-change-me-please-0123456789
APP_OIDC_CLIENT_SECRET=agentforge-api-secret
APP_DB_PASSWORD=agentforge_app_pw
